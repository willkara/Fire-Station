{
  "storage": {
    "FireStationConstants": {
      "service": "DynamoDB",
      "providerPlugin": "awscloudformation"
    }
  },
  "function": {
    "FireStationModels": {
      "providerPlugin": "awscloudformation",
      "service": "LambdaLayer",
      "build": true
    },
    "FireConstantsManager": {
      "build": true,
      "providerPlugin": "awscloudformation",
      "service": "Lambda",
      "dependsOn": [
        {
          "category": "storage",
          "resourceName": "FireStationConstants",
          "attributes": [
            "Name",
            "Arn"
          ]
        },
        {
          "category": "function",
          "resourceName": "FireStationModels",
          "attributes": [
            "Arn"
          ]
        }
      ]
    }
  },
  "api": {
    "FireStationAPI": {
      "service": "API Gateway",
      "providerPlugin": "awscloudformation",
      "dependsOn": [
        {
          "category": "function",
          "resourceName": "FireConstantsManager",
          "attributes": [
            "Name",
            "Arn"
          ]
        }
      ]
    }
  }
}